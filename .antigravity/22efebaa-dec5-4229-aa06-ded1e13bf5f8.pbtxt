        replacement_content: "import React from \'react\';\n\nexport default function Stundenplan() {\n  return (\n    <div className=\"p-margin-mobile md:px-margin-desktop py-lg w-full max-w-[1440px] mx-auto min-h-screen\">\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between mb-8 gap-md\">\n        <div>\n          <span className=\"text-xs font-bold text-primary tracking-widest uppercase mb-1 block\">Semesterplaner</span>\n          <h1 className=\"font-display-lg text-3xl font-extrabold text-on-surface\">Stundenplan</h1>\n          <p className=\"font-body-md text-on-surface-variant font-medium bg-primary/5 px-3 py-1 rounded-full inline-block mt-1\">1. Semester 2023/24</p>\n        </div>\n        <div className=\"flex gap-sm\">\n          <button className=\"px-6 py-2.5 bg-primary text-on-primary rounded-2xl font-bold flex items-center gap-2 hover:bg-primary-fixed hover:text-on-primary-container transition-all text-sm active:scale-95 shadow-md\">\n            <span className=\"material-symbols-outlined text-[20px]\">print</span> Drucken\n          </button>\n        </div>\n      </div>\n\n      <div className=\"bg-white border border-outline-variant rounded-3xl overflow-hidden shadow-sm\">\n        <div className=\"grid grid-cols-[80px_repeat(5,1fr)] border-b border-outline-variant bg-slate-50\">\n          <div className=\"p-4 flex items-center justify-center border-r border-outline-variant border-dashed\">\n            <span className=\"material-symbols-outlined text-primary\">schedule</span>\n          </div>\n          <div className=\"p-4 text-center border-r border-outline-variant border-dashed\">\n            <h3 className=\"font-bold text-primary text-sm uppercase tracking-wider\">Montag</h3>\n          </div>\n          <div className=\"p-4 text-center border-r border-outline-variant border-dashed\">\n            <h3 className=\"font-bold text-primary text-sm uppercase tracking-wider\">Dienstag</h3>\n          </div>\n    