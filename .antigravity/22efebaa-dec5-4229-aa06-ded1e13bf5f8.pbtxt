    replacement_infos {
      original_chunk {
        target_content: "import React from \'react\';\n\nexport default function Jahresuebersicht() {\n  return (\n    <div className=\"p-md md:p-margin-desktop max-w-[1440px] mx-auto space-y-lg w-full\">\n      <header className=\"flex flex-col md:flex-row md:items-end justify-between gap-md mb-2\">\n        <div>\n          <h1 className=\"font-headline-lg text-headline-lg text-on-surface mb-2\">Jahres\303\274bersicht 2023/24</h1>\n          <p className=\"font-body-md text-body-md text-on-surface-variant\">Ein \303\234berblick \303\274ber das gesamte Schuljahr, Ferien und Pr\303\274fungstermine.</p>\n        </div>\n      </header>\n\n      <section className=\"flex flex-wrap gap-md py-4 border-y border-outline-variant mb-6\">\n        <div className=\"flex items-center gap-2\">\n          <span className=\"w-3.5 h-3.5 rounded-sm bg-secondary-container\"></span>\n          <span className=\"font-label-sm text-label-sm uppercase tracking-wider\">Ferien</span>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <span className=\"w-3.5 h-3.5 rounded-sm bg-tertiary-fixed\"></span>\n          <span className=\"font-label-sm text-label-sm uppercase tracking-wider\">Pr\303\274fungen</span>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <span className=\"w-3.5 h-3.5 rounded-sm bg-primary-fixed\"></span>\n          <span className=\"font-label-sm text-label-sm uppercase tracking-wider\">Konferenzen</span>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <span className=\"w-3.5 h-3.5 rounded-sm bg-error-container\"></span>\n          <span className=\"font-label-sm text-label-sm uppercase tracking-wider\">Feiertage</span>\n        </div>\n      </section>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-md\">\n        {/* August 2023 */}\n        <article className=\"bg-surface-container-lowest border border-outline-variant p-md rounded-xl sheet-shadow\">\n          <header className=\"flex justify-between items-center mb-md\">\n            <h3 className=\"font-title-md text-title-md text-primary font-semibold\">August 2023</h3>\n            <span className=\"material-symbols-outlined text-outline cursor-pointer\">more_vert</span>\n          </header>\n          <div className=\"grid grid-cols-7 gap-1 mb-2\">\n            <div className=\"text-center font-label-sm text-on-surface-variant py-1\">M</div>\n            <div className=\"text-center font-label-sm text-on-surface-variant py-1\">D</div>\n            <div className=\"text-center font-label-sm text-on-surface-variant py-1\">M</div>\n            <div className=\"text-center font-label-sm text-on-surface-variant py-1\">D</div>\n            <div className=\"text-center font-label-sm text-on-surface-variant py-1\">F</div>\n            <div className=\"text-center font-label-sm text-error py-1\">S</div>\n            <div className=\"text-center font-label-sm text-error py-1\">S</div>\n          </div>\n          <div className=\"grid grid-cols-7 gap-1\">\n            <div className=\"py-2\"></div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">1</div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">2</div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">3</div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">4</div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">5</div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">6</div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">7</div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">8</div>\n            <div className=\"py-2 text-center text-on-surface-variant font-label-sm\">9</div>\n            <div className=