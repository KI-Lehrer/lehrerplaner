er: #451a03;\n  --color-on-primary: #ffffff;\n  --color-on-tertiary: #ffffff;\n  --color-primary-fixed-dim: #cbd5e1;\n\n  --spacing-gutter: 24px;\n  --spacing-margin-mobile: 16px;\n  --spacing-xl: 64px;\n  --spacing-lg: 32px;\n  --spacing-base: 8px;\n  --spacing-xs: 4px;\n  --spacing-sm: 12px;\n  --spacing-md: 24px;\n  --spacing-margin-desktop: 48px;\n\n  --font-body-lg: \"Hanken Grotesk\", sans-serif;\n  --font-label-sm: \"Hanken Grotesk\", sans-serif;\n  --font-title-md: \"Hanken Grotesk\", sans-serif;\n  --font-headline-lg-mobile: \"Hanken Grotesk\", sans-serif;\n  --font-display-lg: \"Hanken Grotesk\", sans-serif;\n  --font-label-md: \"Hanken Grotesk\", sans-serif;\n  --font-headline-lg: \"Hanken Grotesk\", sans-serif;\n  --font-body-md: \"Hanken Grotesk\", sans-serif;\n}\n\n@layer utilities {\n  .text-body-lg { font-size: 18px; line-height: 28px; font-weight: 400; }\n  .text-label-sm { font-size: 12px; line-height: 16px; font-weight: 650; text-transform: uppercase; letter-spacing: 0.05em; }\n  .text-title-md { font-size: 20px; line-height: 28px; font-weight: 600; letter-spacing: -0.01em; }\n  .text-headline-lg-mobile { font-size: 24px; line-height: 32px; font-weight: 700; letter-spacing: -0.02em; }\n  .text-display-lg { font-size: 40px; line-height: 48px; font-weight: 800; letter-spacing: -0.03em; }\n  .text-label-md { font-size: 14px; line-height: 20px; font-weight: 600; letter-spacing: 0.01em; }\n  .text-headline-lg { font-size: 32px; line-height: 40px; font-weight: 800; letter-spacing: -0.02em; }\n  .text-body-md { font-size: 16px; line-height: 24px; font-weight: 400; }\n  \n  .font-body-lg { font-family: var(--font-body-lg); }\n  .font-label-sm { font-family: var(--font-label-sm); }\n  .font-title-md { font-family: var(--font-title-md); }\n  .font-headline-lg-mobile { font-family: var(--font-headline-lg-mobile); }\n  .font-display-lg { font-family: var(--font-display-lg); }\n  .font-label-md { font-family: var(--font-label-md); }\n  .font-headline-lg { font