    replacement_chunks {
      replacement_content: "import React from \'react\';\n\nexport default function Wochenuebersicht() {\n  return (\n    <div className=\"p-margin-mobile md:px-margin-desktop py-lg w-full max-w-[1440px] mx-auto min-h-screen\">\n      <div className=\"flex flex-col md:flex-row md:items-end justify-between mb-lg gap-md\">\n        <div>\n          <h1 className=\"font-headline-lg text-headline-lg text-on-surface mb-xs font-semibold\">Wochen\303\274bersicht</h1>\n          <p className=\"font-body-md text-on-surface-variant italic mt-1\">KW 42 \342\200\242 16. Oktober \342\200\223 22. Oktober 2023</p>\n        </div>\n        <div className=\"flex gap-sm\">\n          <button className=\"bg-surface-container-high text-on-surface-variant px-5 py-2.5 rounded-full font-label-md flex items-center gap-2 border border-outline-variant hover:bg-surface-container-low transition-colors\">\n            <span className=\"material-symbols-outlined text-[20px]\">chevron_left</span> Vorherige\n          </button>\n          <button className=\"bg-surface-container-high text-on-surface-variant px-5 py-2.5 rounded-full font-label-md flex items-center gap-2 border border-outline-variant hover:bg-surface-container-low transition-colors\">\n            N\303\244chste <span className=\"material-symbols-outlined text-[20px]\">chevron_right</span>\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-3 xl:grid-cols-5 gap-gutter items-stretch\">\n        \n        {/* Montag */}\n        <article className=\"bg-surface-container-lowest border border-outline-variant rounded-xl sheet-shadow flex flex-col h-[700px]\">\n          <header className=\"p-4 border-b border-outline-variant bg-surface-container-low rounded-t-xl shrink-0\">\n            <h4 className=\"font-headline-sm text-primary text-xl font-semibold\">Montag</h4>\n            <span className=\"font-label-md text-on-surface-variant mt-1 block\">16. Oktober</span>\n          </header>\n          <div className=\"p-4 flex-1 flex flex-col gap-3 overflow-y-auto w-full\">\n            <div className=\"h-40 p-3 bg-green-50 border-l-4 border-green-400 flex flex-col justify-between shrink-0\">\n              <div className=\"flex flex-col\">\n                <span className=\"font-label-sm text-green-700 uppercase tracking-wider font-bold\">08:20 - BS</span>\n                <p className=\"font-body-md mt-2 font-medium text-green-900\">Bewegung und Sport</p>\n              </div>\n              <div className=\"mt-auto pt-2 border-t border-green-400/30\">\n                <p className=\"text-label-sm italic text-green-700/60\">Notizen...</p>\n              </div>\n            </div>\n            \n            <div className=\"h-40 p-3 bg-surface-container-low border-l-4 border-outline-variant flex flex-col justify-between shrink-0\">\n              <div className=\"flex flex-col\">\n                <span className=\"font-label-sm text-on-surface-variant uppercase tracking-wider font-bold\">09:10 - X</span>\n                <p className=\"font-body-md mt-2 font-medium\">Unterricht</p>\n              </div>\n              <div className=\"mt-auto pt-2 border-t border-outline-variant/30\">\n                <p className=\"text-label-sm italic text-on-surface-variant/60\">Notizen...</p>\n              </div>\n            </div>\n\n            <div className=\"h-40 p-3 bg-blue-50 border-l-4 border-blue-400 flex flex-col justify-between shrink-0\">\n              <div className=\"flex flex-col\">\n                <span className=\"font-label-sm text-blue-700 uppercase tracking-wider font-bold\">10:15 - F</span>\n                <p className=\"font-body-md mt-2 font-medium text-blue-900\">Franz\303\266sisch</p>\n              </div>\n              <div className=\"mt-auto pt-2 border-t border-blue-400/30\">\n                <p className=\"text-label-sm italic text-blue-700/60\">Notizen...</p>\n              </div>\n            </div>\n\n            <div className=\"h-40 p-3 bg-pink-50 border-l-4 border-pink-400 flex flex-col justify-between shrink-0\">\n              <div className=\"flex flex-col\">\n                <span className=\"font-label-sm text-pink-700 uppercase tracking-wider font-bold\">13:30 - Chor</span>\n                <p className=\"font-body-md mt-2 font-medium text-pink-900\">Chor</p>\n              </div>\n              <div className=\"mt-auto pt-2 border-t border-pink-400/30\">\n                <p className=\"text-label-sm italic text-pink-700/60\">Notizen...</p>\n              </div>\n            </div>\n\n            <div className=\"h-40 p-3 bg-surface-container-low border-l-4 border-outline-variant flex flex-col justify-between shrink-0\">\n              <div className=\"flex flex-col\">\n                <span className=\"font-label-sm text-on-surface-variant uppercase tracking-wider font-bold\">14:20 - X / Pool</span>\n                <p className=\"font-body-md mt-2 font-medium\">Unterricht / Pool</p>\n              </div>\n              <div className=\"mt-auto pt-2 border-t border-outline-variant/30\">\n                <p className=\"text-label-sm italic text-on-surface-variant/60\">Notizen...</p>\n              </div>\n            </div>\n\n            <textarea \n              className=\"w-full notebook-input border-none focus:ring-0 font-body-md italic text-on-surface-variant flex-1 min-h-[160px] resize-none outline-none mt-2 bg-transparent\" \n              placeholder=\"Notizen...\"\n            ></textarea>\n          </div>\n        </article>\n\n        {/* Dienstag */}\n        <article className=\"bg-surface-container-lowest border border-outline-variant rounded-xl sheet-shadow flex flex-col h-[700px]\">\n          <header className=\"p-4 border-b border-outline-variant bg-surface-container-low rounded-t-xl shrink-0\">\n            <h4 className=\"font-headline-sm text-primary text-xl font-semibold\">Dienstag</h4>\n            <span className=\"font-label-md text-on-surface-variant mt-1 block\">17. Oktober</span>\n          </header>\n          <div className=\"p-4 flex-1 h-full\">\n            <textarea \n              className=\"w-full notebook-input border-none focus:ring-0 font-body-md italic text-on-surface-variant h-full resize-none outline-none bg-transparent\" \n              placeholder=\"Notizen...\"\n            ></textarea>\n          </div>\n        </article>\n\n        {/* Mittwoch */}\n        <article className=\"bg-surface-container-lowest border border-outline-variant rounded-xl sheet-shadow flex flex-col h-[700px]\">\n          <header className=\"p-4 border-b border-outline-variant bg-surface-container-low rounded-t-xl shrink-0\">\n            <h4 className=\"font-headline-sm text-primary text-xl font-semibold\">Mittwoch</h4>\n            <span className=\"font-label-md text-on-surface-variant mt-1 block\">18. Oktober</span>\n          </header>\n          <div className=\"p-4 flex-1 h-full\">\n            <textarea \n              className=\"w-full notebook-input border-none focus:ring-0 font-body-md italic text-on-surface-variant h-full resize-none outline-none bg-transparent\" \n              placeholder=\"Wichtigste Themen heute...\"\n            ></textarea>\n          </div>\n        </article>\n\n        {/* Donnerstag */}\n        <article className=\"bg-surface-container-lowest border border-outline-variant rounded-xl sheet-shadow flex flex-col h-[700px]\">\n          <header className=\"p-4 border-b border-outline-variant bg-surface-container-low rounded-t-xl shrink-0\">\n            <h4 className=\"font-headline-sm text-primary text-xl font-semibold\">Donnerstag</h4>\n            <span className=\"font-label-md text-on-surface-variant mt-1 block\">19. Oktober</span>\n          </header>\n          <div className=\"p-4 flex-1 h-full\">\n            <textarea \n              className=\"w-full notebook-input border-none focus:ring-0 font-body-md italic text-on-surface-variant h-full resize-none outline-none bg-transparent\" \n              placeholder=\"Notizen...\"\n            ></textarea>\n          </div>\n        </article>\n\n        {/* Freitag */}\n        <article className=\"bg-surface-container-lowest border border-outline-variant rounded-xl sheet-shadow flex flex-col h-[700px]\">\n          <header className=\"p-4 border-b border-outline-variant bg-surface-container-low rounded-t-xl shrink-0\">\n            <h4 className=\"font-headline-sm text-primary text-xl font-semibold\">Freitag</h4>\n            <span className=\"font-label-md text-on-surface-variant mt-1 block\">20. Oktober</span>\n          </header>\n          <div className=\"p-4 flex-1 h-full\">\n            <textarea \n              className=\"w-full notebook-input border-none focus:ring-0 font-body-md italic text-on-surface-variant h-full resize-none outline-none bg-transparent\" \n              placeholder=\"Wochenabschluss...\"\n            ></textarea>\n          </div>\n        </article>\n        \n      </div>\n    </div>\n  );\n}"
