      target_content: "import React from \'react\';\n\nexport default function Dashboard() {\n  return (\n    <div className=\"max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop py-lg w-full\">\n      <section className=\"mb-lg\">\n        <div className=\"flex flex-col md:flex-row md:items-end justify-between gap-md\">\n          <div>\n            <h1 className=\"font-headline-lg text-headline-lg text-primary mb-2\">Guten Morgen, Frau Schmidt</h1>\n            <p className=\"font-body-lg text-body-lg text-on-surface-variant\">Heute ist Dienstag, der 24. Oktober 2023</p>\n          </div>\n          <div className=\"flex gap-sm\">\n            <div className=\"bg-surface-container-high rounded-xl p-4 flex flex-col items-center justify-center min-w-[100px] border border-outline-variant\">\n              <span className=\"text-label-sm text-on-surface-variant uppercase mb-1\">Temperatur</span>\n              <span className=\"font-title-md text-primary\">12\302\260C</span>\n            </div>\n            <div className=\"bg-tertiary-fixed rounded-xl p-4 flex flex-col items-center justify-center min-w-[100px] border border-outline-variant\">\n              <span className=\"text-label-sm text-on-tertiary-fixed-variant uppercase mb-1\">Stunden</span>\n              <span className=\"font-title-md text-tertiary\">6 Einheiten</span>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-12 gap-gutter\">\n        <div className=\"md:col-span-8 bg-surface-container-lowest sheet-shadow rounded-xl p-md overflow-hidden relative\">\n          <div className=\"flex justify-between items-center mb-md\">\n            <h3 className=\"font-title-md text-primary flex items-center gap-2\">\n              <span className=\"material-symbols-outlined\">schedule</span>\n              Heutiger Stundenplan\n            </h3>\n            <button className=\"text-label-md text-primary hover:underline\">Vollst\303\244ndige Ansicht</button>\n          </div>\n          \n          <div className=\"space-y-sm\">\n            <div className=\"flex items-center gap-md p-4 rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors group cursor-pointer\">\n              <div className=\"text-center min-w-[60px]\">\n                <p className=\"font-label-sm text-on-surface-variant\">08:00</p>\n                <p className=\"font-label-md text-primary font-bold mt-1\">1. Std</p>\n              </div>\n              <div className=\"w-1 self-stretch bg-secondary rounded-full\"></div>\n              <div className=\"flex-grow\">\n                <p className=\"font-title-md text-on-surface\">Mathematik</p>\n                <p className=\"text-label-md text-on-surface-variant mt-1\">Klasse 8b | Raum 204</p>\n              </div>\n              <div className=\"opacity-0 group-hover:opacity-100 transition-opacity\">\n                <span className=\"material-symbols-outlined text-on-surface-variant\">chevron_right</span>\n              </div>\n            </div>\n\n            <div className=\"flex items-center gap-md p-4 rounded-lg bg-tertiary-fixed/30 border border-tertiary/20 group relative overflow-hidden cursor-pointer\">\n              <div className=\"absolute left-0 top-0 h-full w-1 bg-tertiary\"></div>\n              <div className=\"text-center min-w-[60px]\">\n                <p className=\"font-label-sm text-on-tertiary-fixed-variant\">08:50</p>\n                <p className=\"font-label-md text-tertiary font-bold mt-1\">2. Std</p>\n              </div>\n              <div className=\"flex-grow\">\n                <div className=\"flex items-center gap-2 mb-1\">\n                  <p className=\"font-title-md text-on-surface\">Deutsch</p>\n                  <span className=\"bg-tertiary text-on-tertiary text-[10px] px-2 py-0.5 rounded-full uppercase font-bold tracking-wider\">Aktuell</span>\n                </div>\n                <p className=\"text-label-md text-on-surface-variant\">Klasse 10a | Raum 112</p>\n              </div>\n              <span className=\"material-symbols-outlined text-tertiary animate-pulse\">more_horiz</span>\n            </div>\n\n            <div className=\"flex items-center gap-md p-4 rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors group cursor-pointer\">\n              <div className=\"text-center min-w-[60px]\">\n                <p className=\"font-label-sm text-on-surface-variant\">10:00</p>\n                <p className=\"font-label-md text-primary font-bold mt-1\">3. Std</p>\n              </div>\n              <div className=\"w-1 self-stretch bg-primary-container rounded-full\"></div>\n              <div className=\"flex-grow\">\n                <p className=\"font-title-md text-on-surface\">Physik</p>\n                <p className=\"text-label-md text-on-surface-variant mt-1\">Klasse 9c | Labor B</p>\n              </div>\n              <div className=\"opacity-0 group-hover:opacity-100 transition-opacity\">\n                <span className=\"material-symbols-outlined text-on-surface-variant\">chevron_right</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"md:col-span-4 bg-surface-container-lowest sheet-shadow rounded-xl p-md\">\n          <h3 className=\"font-title-md text-primary mb-md flex items-center gap-2\">\n            <span className=\"material-symbols-outlined\">priority_high</span>\n            Top Priorit\303\244ten\n          </h3>\n          <div className=\"space-y-md\">\n            <label className=\"flex items-start gap-sm cursor-pointer group\">\n              <input className=\"mt-1 rounded-sm border-outline text-primary focus:ring-primary h-5 w-5 transition-all\" type=\"checkbox\" />\n              <div className=\"flex flex-col ml-1\">\n                <span className=\"font-label-md text-on-surface group-hover:text-primary transition-colors\">Elternbriefe unterschreiben (8b)</span>\n                <span className=\"text-label-sm text-error font-semibold flex items-center gap-1 mt-1\">\n                  <span className=\"material-symbols-outlined text-[14px]\">event</span>Bis heute, 14:00\n                </span>\n              </div>\n            </label>\n            <label className=\"flex items-start gap-sm cursor-pointer group mt-4\">\n              <input className=\"mt-1 rounded-sm border-outline text-primary focus:ring-primary h-5 w-5 transition-all\" type=\"checkbox\" />\n              <div className=\"flex flex-col ml-1\">\n                <span className=\"font-label-md text-on-surface group-hover:text-primary transition-colors\">Klausur Mathematik korrigieren</span>\n                <span className=\"text-label-sm text-on-surface-variant mt-1\">Noch 12 Hefte offen</span>\n              </div>\n            </label>\n            <label className=\"flex items-start gap-sm cursor-pointer group mt-4\">\n              <input className=\"mt-1 rounded-sm border-outline text-primary focus:ring-primary h-5 w-5 transition-all\" type=\"checkbox\" />\n              <div className=\"flex flex-col ml-1\">\n                <span className=\"font-label-md text-on-surface group-hover:text-primary transition-colors\">Material f\303\274r Wandertag pr\303\274fen</span>\n                <span className=\"text-label-sm text-on-surface-variant mt-1\">Abgabe bei Schulleitung</span>\n              </div>\n            </label>\n          </div>\n          <button className=\"w-full mt-lg py-2.5 border border-outline-variant text-label-md text-on-surface-variant rounded-lg hover:bg-surface-container-low transition-colors mt-6\">\n            Alle Aufgaben anzeigen\n          </button>\n        </div>\n\n        <div className=\"md:col-span-12 lg:col-span-12 grid grid-cols-2 md:grid-cols-4 gap-gutter mt-4\">\n          <button className=\"bg-surface-container-lowest sheet-shadow rounded-xl p-md flex flex-col items-center justify-center gap-sm hover:bg-primary/5 transition-all group py-6\">\n            <div className=\"w-12 h-12 rounded-full bg-primary-fixed flex items-center justify-center group-hover:scale-110 transition-transform mb-3\">\n              <span className=\"material-symbols-outlined text-primary\">edit_note</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Kursbuch</span>\n          </button>\n          <button className=\"bg-surface-container-lowest sheet-shadow rounded-xl p-md flex flex-col items-center justify-center gap-sm hover:bg-tertiary/5 transition-all group py-6\">\n            <div className=\"w-12 h-12 rounded-full bg-tertiary-fixed flex items-center justify-center group-hover:scale-110 transition-transform mb-3\">\n              <span className=\"material-symbols-outlined text-tertiary\">inventory_2</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Archiv</span>\n          </button>\n          <button className=\"bg-surface-container-lowest sheet-shadow rounded-xl p-md flex flex-col items-center justify-center gap-sm hover:bg-primary-container/5 transition-all group py-6\">\n            <div className=\"w-12 h-12 rounded-full bg-primary-fixed-dim flex items-center justify-center group-hover:scale-110 transition-transform mb-3\">\n              <span className=\"material-symbols-outlined text-on-primary-fixed-variant\">contact_support</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Hilfe</span>\n          </button>\n        </div>\n\n        <div className=\"md:col-span-12 bg-primary-container text-on-primary-container rounded-xl p-lg relative overflow-hidden min-h-[160px] flex items-center mt-4\">\n          <div className=\"relative z-10 max-w-2xl px-4 py-2\">\n            <p className=\"font-body-lg text-body-lg italic mb-xs opacity-90 pb-3\">\"Bildung ist die m\303\244chtigste Waffe, die man verwenden kann, um die Welt zu ver\303\244ndern.\"</p>\n            <p className=\"font-label-md text-on-primary-fixed font-bold tracking-widest uppercase opacity-75 md:text-sm\">\342\200\224 Nelson Mandela</p>\n          </div>\n          <div className=\"absolute right-0 top-0 w-1/3 h-full opacity-10 flex items-center justify-center overflow-hidden\">\n            <span className=\"material-symbols-outlined text-[160px] select-none\">format_quote</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"
      replacement_content: "import React from \'react\';\n\nexport default function Dashboard() {\n  return (\n    <div className=\"max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop py-lg w-full\">\n      {/* Upper header section */}\n      <section className=\"mb-8\">\n        <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-md\">\n          <div>\n            <span className=\"text-xs font-bold text-primary tracking-widest uppercase mb-1 block\">Lehrplaner Dashboard</span>\n            <h1 className=\"font-headline-lg text-headline-lg text-on-surface\">Guten Morgen, Frau Schmidt</h1>\n            <p className=\"font-body-lg text-body-lg text-on-surface-variant\">Dienstag, der 24. Oktober 2023 \342\200\242 Woche B</p>\n          </div>\n          <div className=\"flex items-center gap-4\">\n            <div className=\"px-4 py-2 bg-white border border-outline-variant rounded-full text-sm font-semibold text-on-surface shadow-sm flex items-center gap-2\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-primary animate-pulse\"></span>\n              Schultag 48 von 180\n            </div>\n          </div>\n        </div>\n      </section>\n\n      {/* Main Bento Grid layout */}\n      <div className=\"grid grid-cols-1 md:grid-cols-4 gap-gutter\">\n        \n        {/* Main Highlight Card (2x2 span inside the bento column setup) */}\n        <div className=\"md:col-span-3 bg-primary rounded-3xl p-8 text-white flex flex-col justify-between shadow-lg relative overflow-hidden bento-glow-indigo min-h-[320px]\">\n          <div className=\"relative z-10\">\n            <span className=\"px-3 py-1 bg-white/20 rounded-full text-[11px] font-bold uppercase tracking-wider mb-5 inline-block\">Aktuelle Lektion</span>\n            <h2 className=\"text-3xl md:text-4xl font-extrabold leading-tight\">Deutsch \342\200\224 Klasse 10a<br />Goethe: Faust I</h2>\n            <p className=\"mt-4 text-primary-fixed/80 max-w-lg font-body-md text-body-md\">\n              Szenenanalyse im \"Studierzimmer\". Arbeitsbl\303\244tter sind ausgeteilt, Smartboard-Pr\303\244sentation l\303\244uft.\n            </p>\n          </div>\n          <div className=\"relative z-10 flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-t border-white/10 pt-5 mt-6\">\n            <div className=\"flex items-center gap-md\">\n              <div className=\"flex items-center gap-1\">\n                <span className=\"material-symbols-outlined text-[20px] text-primary-fixed\">room</span>\n                <span className=\"font-label-md text-white\">Raum 112</span>\n              </div>\n              <div className=\"flex items-center gap-1\">\n                <span className=\"material-symbols-outlined text-[20px] text-primary-fixed\">schedule</span>\n                <span className=\"font-label-md text-white\">08:50 - 09:35</span>\n              </div>\n            </div>\n            <button className=\"px-6 py-2.5 bg-white text-primary rounded-2xl font-bold hover:bg-primary-fixed hover:text-on-primary-container transition-all text-sm active:scale-95 shadow-sm\">\n              Kursbuch aufrufen\n            </button>\n          </div>\n          {/* Decorative background visual blob */}\n          <div className=\"absolute -bottom-16 -right-16 w-72 h-72 bg-indigo-500 rounded-full blur-3xl opacity-40\"></div>\n        </div>\n\n        {/* Metric Card 1: Temperature (1x1) */}\n        <div className=\"bg-white border border-outline-variant rounded-3xl p-6 flex flex-col justify-between shadow-sm hover:border-slate-300 transition-colors\">\n          <div className=\"flex justify-between items-start\">\n            <div className=\"w-10 h-10 bg-secondary-container rounded-xl flex items-center justify-center text-on-secondary-container\">\n              <span className=\"material-symbols-outlined\">device_thermostat</span>\n            </div>\n            <span className=\"text-xs font-bold text-on-secondary-container bg-secondary-container px-2.5 py-0.5 rounded-full uppercase tracking-wider\">Oktober</span>\n          </div>\n          <div>\n            <div className=\"text-3xl font-extrabold text-on-surface\">12\302\260C</div>\n            <div className=\"text-sm text-on-surface-variant font-semibold mt-1\">Drau\303\237en k\303\274hl & klar</div>\n          </div>\n        </div>\n\n        {/* Metric Card 2: Units of day (1x1) */}\n        <div className=\"bg-tertiary-fixed border border-outline-variant/40 rounded-3xl p-6 flex flex-col justify-between shadow-sm hover:shadow-md transition-shadow\">\n          <div className=\"flex justify-between items-start\">\n            <div className=\"w-10 h-10 bg-white/70 rounded-xl flex items-center justify-center text-on-tertiary-fixed-variant\">\n              <span className=\"material-symbols-outlined\">menu_book</span>\n            </div>\n            <span className=\"text-xs font-bold text-on-tertiary-fixed-variant bg-white/55 px-2.5 py-0.5 rounded-full\">Heute</span>\n          </div>\n          <div>\n            <div className=\"text-3xl font-extrabold text-on-tertiary-fixed-variant\">6 Einheiten</div>\n            <div className=\"text-sm text-on-tertiary-fixed-variant/90 font-semibold mt-1\">Voll geplanter Tag</div>\n          </div>\n        </div>\n\n        {/* Timetable card (2x1 wide span in details) */}\n        <div className=\"md:col-span-2 bg-white border border-outline-variant rounded-3xl p-6 shadow-sm flex flex-col justify-between hover:border-slate-300 transition-colors\">\n          <div>\n            <div className=\"flex justify-between items-center mb-4\">\n              <h3 className=\"font-title-md text-title-md text-on-surface flex items-center gap-2\">\n                <span className=\"material-symbols-outlined text-primary\">schedule</span>\n                Heute verbleibend\n              </h3>\n              <span className=\"text-xs font-mono text-on-surface-variant uppercase tracking-wider font-bold bg-surface-container px-2 py-0.5 rounded\">Vorschau</span>\n            </div>\n            \n            <div className=\"space-y-3\">\n              <div className=\"flex items-center gap-md p-3 rounded-2xl border border-outline-variant hover:bg-surface-container-low transition-colors cursor-pointer group\">\n                <div className=\"text-center min-w-[50px]\">\n                  <p className=\"font-label-sm text-on-surface-variant\">10:00</p>\n                  <p className=\"text-[11px] text-primary font-bold\">3. Std</p>\n                </div>\n                <div className=\"w-1 self-stretch bg-primary rounded-full\"></div>\n                <div className=\"flex-grow\">\n                  <p className=\"font-label-md text-on-surface leading-tight\">Physik \342\200\224 Klasse 9c</p>\n                  <p className=\"text-xs text-on-surface-variant mt-0.5\">Optik-Labor B</p>\n                </div>\n                <span className=\"material-symbols-outlined text-outline opacity-0 group-hover:opacity-100 transition-opacity\">chevron_right</span>\n              </div>\n\n              <div className=\"flex items-center gap-md p-3 rounded-2xl border border-outline-variant hover:bg-surface-container-low transition-colors cursor-pointer group\">\n                <div className=\"text-center min-w-[50px]\">\n                  <p className=\"font-label-sm text-on-surface-variant\">11:45</p>\n                  <p className=\"text-[11px] text-primary font-bold\">5. Std</p>\n                </div>\n                <div className=\"w-1 self-stretch bg-secondary rounded-full\"></div>\n                <div className=\"flex-grow\">\n                  <p className=\"font-label-md text-on-surface leading-tight\">Mathematik \342\200\224 Klasse 8b</p>\n                  <p className=\"text-xs text-on-surface-variant mt-0.5\">Raum 204</p>\n                </div>\n                <span className=\"material-symbols-outlined text-outline opacity-0 group-hover:opacity-100 transition-opacity\">chevron_right</span>\n              </div>\n            </div>\n          </div>\n          \n          <button className=\"w-full mt-4 py-2 bg-surface-container-low hover:bg-surface-container text-label-md text-primary rounded-xl transition-colors font-bold text-center\">\n            Vollst\303\244ndigen Stundenplan ansehen\n          </button>\n        </div>\n\n        {/* Priority card styled as deep-slate-950 high-contrast bento item */}\n        <div className=\"bg-slate-900 rounded-3xl p-6 text-white shadow-lg flex flex-col justify-between\">\n          <div>\n            <div className=\"flex justify-between items-start mb-4\">\n              <span className=\"text-xs font-bold text-amber-400 uppercase tracking-widest\">Wichtig</span>\n              <span className=\"material-symbols-outlined text-amber-400\">notifications_active</span>\n            </div>\n            <h3 className=\"font-title-md text-title-md text-white mb-4\">Top Priorit\303\244ten</h3>\n            \n            <div className=\"space-y-3.5\">\n              <label className=\"flex items-start gap-3 cursor-pointer group\">\n                <input className=\"mt-1 rounded border-slate-700 bg-slate-800 text-primary focus:ring-primary focus:ring-offset-slate-900 h-4 w-4 transition-all\" type=\"checkbox\" />\n                <div className=\"flex flex-col\">\n                  <span className=\"text-sm font-medium text-slate-100 group-hover:text-primary transition-colors\">Elternbriefe (8b) sichten</span>\n                  <span className=\"text-[10px] text-error font-bold mt-0.5\">Bis 14:00 Uhr</span>\n                </div>\n              </label>\n\n              <label className=\"flex items-start gap-3 cursor-pointer group\">\n                <input className=\"mt-1 rounded border-slate-700 bg-slate-800 text-primary focus:ring-primary focus:ring-offset-slate-900 h-4 w-4 transition-all\" type=\"checkbox\" />\n                <div className=\"flex flex-col\">\n                  <span className=\"text-sm font-medium text-slate-100 group-hover:text-primary transition-colors\">Klausur Mathe korrigieren</span>\n                  <span className=\"text-[10px] text-slate-400 mt-0.5\">12 Hefte verbleibend</span>\n                </div>\n              </label>\n            </div>\n          </div>\n\n          <div className=\"pt-4 border-t border-slate-800 mt-4 text-xs font-semibold uppercase tracking-wider text-slate-400 italic\">\n            3 Aufgaben verbleibend\n          </div>\n        </div>\n\n        {/* Quick Nav Bento Row */}\n        <div className=\"col-span-1 md:col-span-4 grid grid-cols-2 md:grid-cols-3 gap-4\">\n          <button className=\"bg-white border border-outline-variant rounded-2xl p-5 flex flex-col items-center justify-center gap-sm hover:border-primary hover:bg-primary-fixed/20 transition-all group cursor-pointer shadow-sm\">\n            <div className=\"w-11 h-11 rounded-xl bg-primary/10 flex items-center justify-center group-hover:scale-105 transition-transform text-primary\">\n              <span className=\"material-symbols-outlined\">edit_note</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Kursbuch</span>\n          </button>\n\n          <button className=\"bg-white border border-outline-variant rounded-2xl p-5 flex flex-col items-center justify-center gap-sm hover:border-primary hover:bg-primary-fixed/20 transition-all group cursor-pointer shadow-sm\">\n            <div className=\"w-11 h-11 rounded-xl bg-tertiary/10 flex items-center justify-center group-hover:scale-105 transition-transform text-tertiary\">\n              <span className=\"material-symbols-outlined\">inventory_2</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Archiv</span>\n          </button>\n\n          <button className=\"bg-white border border-outline-variant rounded-2xl p-5 col-span-2 md:col-span-1 flex flex-col items-center justify-center gap-sm hover:border-primary hover:bg-primary-fixed/20 transition-all group cursor-pointer shadow-sm\">\n            <div className=\"w-11 h-11 rounded-xl bg-slate-100 flex items-center justify-center group-hover:scale-105 transition-transform text-on-surface-variant\">\n              <span className=\"material-symbols-outlined\">contact_support</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Hilfe / Support</span>\n          </button>\n        </div>\n\n        {/* Large Decorative Quote Bento (Mandela Quote with ultra-clean, minimal charcoal background) */}\n        <div className=\"col-span-1 md:col-span-4 bg-slate-900 rounded-3xl p-8 text-white relative overflow-hidden flex items-center min-h-[160px] shadow-md\">\n          <div className=\"relative z-10 max-w-2xl\">\n            <p className=\"font-body-lg text-lg italic mb-3 text-slate-100 leading-relaxed font-semibold\">\n              \"Bildung ist die m\303\244chtigste Waffe, die man verwenden kann, um die Welt zu ver\303\244ndern.\"\n            </p>\n            <p className=\"font-label-md text-primary-fixed uppercase tracking-widest text-[11px]\">\n              \342\200\224 Nelson Mandela\n            </p>\n          </div>\n          <div className=\"absolute right-6 bottom-0 text-white/5 select-none pointer-events-none\">\n            <span className=\"material-symbols-outlined text-[140px]\">format_quote</span>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  );\n}"
    }
