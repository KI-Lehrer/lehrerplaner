      replacement_content: "import React from \'react\';\n\nexport default function Dashboard() {\n  return (\n    <div className=\"max-w-[1440px] mx-auto px-margin-mobile md:px-margin-desktop py-lg w-full\">\n      <section className=\"mb-lg\">\n        <div className=\"flex flex-col md:flex-row md:items-end justify-between gap-md\">\n          <div>\n            <h1 className=\"font-headline-lg text-headline-lg text-primary mb-2\">Guten Morgen, Frau Schmidt</h1>\n            <p className=\"font-body-lg text-body-lg text-on-surface-variant\">Heute ist Dienstag, der 24. Oktober 2023</p>\n          </div>\n          <div className=\"flex gap-sm\">\n            <div className=\"bg-surface-container-high rounded-xl p-4 flex flex-col items-center justify-center min-w-[100px] border border-outline-variant\">\n              <span className=\"text-label-sm text-on-surface-variant uppercase mb-1\">Temperatur</span>\n              <span className=\"font-title-md text-primary\">12\302\260C</span>\n            </div>\n            <div className=\"bg-tertiary-fixed rounded-xl p-4 flex flex-col items-center justify-center min-w-[100px] border border-outline-variant\">\n              <span className=\"text-label-sm text-on-tertiary-fixed-variant uppercase mb-1\">Stunden</span>\n              <span className=\"font-title-md text-tertiary\">6 Einheiten</span>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-12 gap-gutter\">\n        <div className=\"md:col-span-8 bg-surface-container-lowest sheet-shadow rounded-xl p-md overflow-hidden relative\">\n          <div className=\"flex justify-between items-center mb-md\">\n            <h3 className=\"font-title-md text-primary flex items-center gap-2\">\n              <span className=\"material-symbols-outlined\">schedule</span>\n              Heutiger Stundenplan\n            </h3>\n            <button className=\"text-label-md text-primary hover:underline\">Vollst\303\244ndige Ansicht</button>\n          </div>\n          \n          <div className=\"space-y-sm\">\n            <div className=\"flex items-center gap-md p-4 rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors group cursor-pointer\">\n              <div className=\"text-center min-w-[60px]\">\n                <p className=\"font-label-sm text-on-surface-variant\">08:00</p>\n                <p className=\"font-label-md text-primary font-bold mt-1\">1. Std</p>\n              </div>\n              <div className=\"w-1 self-stretch bg-secondary rounded-full\"></div>\n              <div className=\"flex-grow\">\n                <p className=\"font-title-md text-on-surface\">Mathematik</p>\n                <p className=\"text-label-md text-on-surface-variant mt-1\">Klasse 8b | Raum 204</p>\n              </div>\n              <div className=\"opacity-0 group-hover:opacity-100 transition-opacity\">\n                <span className=\"material-symbols-outlined text-on-surface-variant\">chevron_right</span>\n              </div>\n            </div>\n\n            <div className=\"flex items-center gap-md p-4 rounded-lg bg-tertiary-fixed/30 border border-tertiary/20 group relative overflow-hidden cursor-pointer\">\n              <div className=\"absolute left-0 top-0 h-full w-1 bg-tertiary\"></div>\n              <div className=\"text-center min-w-[60px]\">\n                <p className=\"font-label-sm text-on-tertiary-fixed-variant\">08:50</p>\n                <p className=\"font-label-md text-tertiary font-bold mt-1\">2. Std</p>\n              </div>\n              <div className=\"flex-grow\">\n                <div className=\"flex items-center gap-2 mb-1\">\n                  <p className=\"font-title-md text-on-surface\">Deutsch</p>\n                  <span className=\"bg-tertiary text-on-tertiary text-[10px] px-2 py-0.5 rounded-full uppercase font-bold tracking-wider\">Aktuell</span>\n                </div>\n                <p className=\"text-label-md text-on-surface-variant\">Klasse 10a | Raum 112</p>\n              </div>\n              <span className=\"material-symbols-outlined text-tertiary animate-pulse\">more_horiz</span>\n            </div>\n\n            <div className=\"flex items-center gap-md p-4 rounded-lg border border-outline-variant hover:bg-surface-container-low transition-colors group cursor-pointer\">\n              <div className=\"text-center min-w-[60px]\">\n                <p className=\"font-label-sm text-on-surface-variant\">10:00</p>\n                <p className=\"font-label-md text-primary font-bold mt-1\">3. Std</p>\n              </div>\n              <div className=\"w-1 self-stretch bg-primary-container rounded-full\"></div>\n              <div className=\"flex-grow\">\n                <p className=\"font-title-md text-on-surface\">Physik</p>\n                <p className=\"text-label-md text-on-surface-variant mt-1\">Klasse 9c | Labor B</p>\n              </div>\n              <div className=\"opacity-0 group-hover:opacity-100 transition-opacity\">\n                <span className=\"material-symbols-outlined text-on-surface-variant\">chevron_right</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div className=\"md:col-span-4 bg-surface-container-lowest sheet-shadow rounded-xl p-md\">\n          <h3 className=\"font-title-md text-primary mb-md flex items-center gap-2\">\n            <span className=\"material-symbols-outlined\">priority_high</span>\n            Top Priorit\303\244ten\n          </h3>\n          <div className=\"space-y-md\">\n            <label className=\"flex items-start gap-sm cursor-pointer group\">\n              <input className=\"mt-1 rounded-sm border-outline text-primary focus:ring-primary h-5 w-5 transition-all\" type=\"checkbox\" />\n              <div className=\"flex flex-col ml-1\">\n                <span className=\"font-label-md text-on-surface group-hover:text-primary transition-colors\">Elternbriefe unterschreiben (8b)</span>\n                <span className=\"text-label-sm text-error font-semibold flex items-center gap-1 mt-1\">\n                  <span className=\"material-symbols-outlined text-[14px]\">event</span>Bis heute, 14:00\n                </span>\n              </div>\n            </label>\n            <label className=\"flex items-start gap-sm cursor-pointer group mt-4\">\n              <input className=\"mt-1 rounded-sm border-outline text-primary focus:ring-primary h-5 w-5 transition-all\" type=\"checkbox\" />\n              <div className=\"flex flex-col ml-1\">\n                <span className=\"font-label-md text-on-surface group-hover:text-primary transition-colors\">Klausur Mathematik korrigieren</span>\n                <span className=\"text-label-sm text-on-surface-variant mt-1\">Noch 12 Hefte offen</span>\n              </div>\n            </label>\n            <label className=\"flex items-start gap-sm cursor-pointer group mt-4\">\n              <input className=\"mt-1 rounded-sm border-outline text-primary focus:ring-primary h-5 w-5 transition-all\" type=\"checkbox\" />\n              <div className=\"flex flex-col ml-1\">\n                <span className=\"font-label-md text-on-surface group-hover:text-primary transition-colors\">Material f\303\274r Wandertag pr\303\274fen</span>\n                <span className=\"text-label-sm text-on-surface-variant mt-1\">Abgabe bei Schulleitung</span>\n              </div>\n            </label>\n          </div>\n          <button className=\"w-full mt-lg py-2.5 border border-outline-variant text-label-md text-on-surface-variant rounded-lg hover:bg-surface-container-low transition-colors mt-6\">\n            Alle Aufgaben anzeigen\n          </button>\n        </div>\n\n        <div className=\"md:col-span-12 lg:col-span-12 grid grid-cols-2 md:grid-cols-4 gap-gutter mt-4\">\n          <button className=\"bg-surface-container-lowest sheet-shadow rounded-xl p-md flex flex-col items-center justify-center gap-sm hover:bg-primary/5 transition-all group py-6\">\n            <div className=\"w-12 h-12 rounded-full bg-primary-fixed flex items-center justify-center group-hover:scale-110 transition-transform mb-3\">\n              <span className=\"material-symbols-outlined text-primary\">edit_note</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Kursbuch</span>\n          </button>\n          <button className=\"bg-surface-container-lowest sheet-shadow rounded-xl p-md flex flex-col items-center justify-center gap-sm hover:bg-tertiary/5 transition-all group py-6\">\n            <div className=\"w-12 h-12 rounded-full bg-tertiary-fixed flex items-center justify-center group-hover:scale-110 transition-transform mb-3\">\n              <span className=\"material-symbols-outlined text-tertiary\">inventory_2</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Archiv</span>\n          </button>\n          <button className=\"bg-surface-container-lowest sheet-shadow rounded-xl p-md flex flex-col items-center justify-center gap-sm hover:bg-primary-container/5 transition-all group py-6\">\n            <div className=\"w-12 h-12 rounded-full bg-primary-fixed-dim flex items-center justify-center group-hover:scale-110 transition-transform mb-3\">\n              <span className=\"material-symbols-outlined text-on-primary-fixed-variant\">contact_support</span>\n            </div>\n            <span className=\"font-label-md text-on-surface text-center\">Hilfe</span>\n          </button>\n        </div>\n\n        <div className=\"md:col-span-12 bg-primary-container text-on-primary-container rounded-xl p-lg relative overflow-hidden min-h-[160px] flex items-center mt-4\">\n          <div className=\"relative z-10 max-w-2xl px-4 py-2\">\n            <p className=\"font-body-lg text-body-lg italic mb-xs opacity-90 pb-3\">\"Bildung ist die m\303\244chtigste Waffe, die man verwenden kann, um die Welt zu ver\303\244ndern.\"</p>\n            <p className=\"font-label-md text-on-primary-fixed font-bold tracking-widest uppercase opacity-75 md:text-sm\">\342\200\224 Nelson Mandela</p>\n          </div>\n          <div className=\"absolute right-0 top-0 w-1/3 h-full opacity-10 flex items-center justify-center overflow-hidden\">\n            <span className=\"material-symbols-outlined text-[160px] select-none\">format_quote</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  );\n}"
    }
