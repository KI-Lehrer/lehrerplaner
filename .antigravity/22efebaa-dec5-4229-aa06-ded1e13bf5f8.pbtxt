        target_content: "import React from \'react\';\n\nexport default function Wochenuebersicht() {\n  return (\n    <div className=\"p-margin-mobile md:px-margin-desktop py-lg w-full max-w-[1440px] mx-auto min-h-screen\">\n      <div className=\"flex flex-col md:flex-row md:items-end justify-between mb-lg gap-md\">\n        <div>\n          <h1 className=\"font-headline-lg text-headline-lg text-on-surface mb-xs font-semibold\">Wochen\303\274bersicht</h1>\n          <p className=\"font-body-md text-on-surface-variant italic mt-1\">KW 42 \342\200\242 16. Oktober \342\200\223 22. Oktober 2023</p>\n        </div>\n        <div className=\"flex gap-sm\">\n          <button className=\"bg-surface-container-high text-on-surface-variant px-5 py-2.5 rounded-full font-label-md flex items-center gap-2 border border-outline-variant hover:bg-surface-container-low transition-colors\">\n            <span className=\"material-symbols-outlined text-[20px]\">chevron_left</span> Vorherige\n          </button>\n          <button className=\"bg-surface-container-high text-on-surface-variant px-5 py-2.5 rounded-full font-label-md flex items-center gap-2 border border-outline-variant hover:bg-surface-container-low transition-colors\">\n            N\303\244chste <span className=\"material-symbols-outlined text-[20px]\">chevron_right</span>\n          </button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-3 xl:grid-cols-5 gap-gutter items-stretch\">\n        \n        {/* Montag */}\n        <article className=\"bg-surface-container-lowest border border-outline-variant rounded-xl sheet-shadow flex flex-col h-[700px]\">\n          <header className=\"p-4 border-b border-outline-variant bg-surface-container-low rounded-t-xl shrink-0\">\n            <h4 className=\"font-headline-sm text-primary text-xl font-semibold\">Montag</h4>\n            <span className=\"font-label-md text-on-surface-variant mt-1 block\">16. Oktober</span>\n          </header>