    replacement_chunks {
      replacement_content: "import React from \'react\';\n\nexport default function Stundenplan() {\n  return (\n    <div className=\"p-margin-mobile md:px-margin-desktop py-lg w-full max-w-[1440px] mx-auto min-h-screen\">\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between mb-lg gap-md\">\n        <div>\n          <h1 className=\"font-headline-lg text-headline-lg text-primary mb-xs font-semibold\">Stundenplan</h1>\n          <p className=\"font-body-md text-on-surface-variant font-medium\">1. Semester 2023/24</p>\n        </div>\n        <div className=\"flex gap-sm\">\n          <button className=\"px-5 py-2.5 bg-primary text-on-primary rounded-full font-label-md flex items-center gap-2 hover:bg-primary/90 transition-colors sheet-shadow\">\n            <span className=\"material-symbols-outlined text-[20px]\">print</span> Drucken\n          </button>\n        </div>\n      </div>\n\n      <div className=\"bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden sheet-shadow\">\n        <div className=\"grid grid-cols-[80px_repeat(5,1fr)] border-b border-outline-variant bg-surface-container-low\">\n          <div className=\"p-4 flex items-center justify-center border-r border-outline-variant border-dashed\">\n            <span className=\"material-symbols-outlined text-on-surface-variant\">schedule</span>\n          </div>\n          <div className=\"p-4 text-center border-r border-outline-variant border-dashed\">\n            <h3 className=\"font-title-md font-semibold text-primary\">Montag</h3>\n          </div>\n          <div className=\"p-4 text-center border-r border-outline-variant border-dashed\">\n            <h3 className=\"font-title-md font-semibold text-primary\">Dienstag</h3>\n          </div>\n          <div className=\"p-4 text-center border-r border-outline-variant border-dashed\">\n            <h3 className=\"font-title-md font-semibold text-primary\">Mittwoch</h3>\n          </div>\n          <div className=\"p-4 text-center border-r border-outline-variant border-dashed\">\n            <h3 className=\"font-title-md font-semibold text-primary\">Donnerstag</h3>\n          </div>\n          <div className=\"p-4 text-center\">\n            <h3 className=\"font-title-md font-semibold text-primary\">Freitag</h3>\n          </div>\n        </div>\n\n        {/* 1. Lektion */}\n        <div className=\"grid grid-cols-[80px_repeat(5,1fr)] border-b border-outline-variant group hover:bg-surface-container/30 transition-colors\">\n          <div className=\"p-3 text-center border-r border-outline-variant border-dashed flex flex-col justify-center bg-surface-container-low/50\">\n            <span className=\"font-label-md font-bold text-on-surface\">1</span>\n            <span className=\"text-label-sm text-on-surface-variant mt-1\">08:20<br/>09:05</span>\n          </div>\n          <div className=\"p-2 border-r border-outline-variant border-dashed relative\">\n            <div className=\"absolute inset-2 bg-green-100 rounded-lg border-l-4 border-green-500 p-2 flex flex-col hover:scale-[1.02] transition-transform cursor-pointer shadow-sm\">\n              <span className=\"font-title-md font-bold text-green-900\">BS</span>\n              <span className=\"text-sm font-medium text-green-800\">MoS</span>\n              <span className=\"mt-auto text-xs font-semibold text-green-700\">SH1</span>\n            </div>\n          </div>\n          <div className=\"p-2 border-r border-outline-variant border-dashed relative\">\n            <div className=\"absolute inset-2 bg-blue-100 rounded-lg border-l-4 border-blue-500 p-2 flex flex-col hover:scale-[1.02] transition-transform cursor-pointer shadow-sm\">\n              <span className=\"font-title-md font-bold text-blue-900\">F</span>\n              <span className=\"text-sm font-medium text-blue-800\">MaL</span>\n              <span className=\"mt-auto text-xs font-semibold text-blue-700\">D 02</span>\n            </div>\n          </div>\n          <div className=\"p-2 border-r border-outline-variant border-dashed relative\">\n            <div className=\"absolute inset-2 bg-yellow-100 rounded-lg border-l-4 border-yellow-500 p-2 flex flex-col hover:scale-[1.02] transition-transform cursor-pointer shadow-sm\">\n              <span className=\"font-title-md font-bold text-yellow-900\">SpH</span>\n              <span className=\"text-sm font-medium text-yellow-800\">BrM</span>\n              <span className=\"mt-auto text-xs font-semibold text-yellow-700\">D 02</span>\n            </div>\n          </div>\n          <div className=\"p-2 border-r border-outline-variant border-dashed relative\">\n             <div className=\"absolute inset-2 bg-cyan-100 rounded-lg border-l-4 border-cyan-500 p-2 flex flex-col hover:scale-[1.02] transition-transform cursor-pointer shadow-sm\">\n              <span className=\"font-title-md font-bold text-cyan-900\">IfL</span>\n              <span className=\"text-sm font-medium text-cyan-800\">LiR</span>\n              <span className=\"mt-auto text-xs font-semibold text-cyan-700\">Zi 06</span>\n            </div>\n          </div>\n          <div className=\"p-2 relative bg-[url(\'data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PHBhdGggZD0iTTAgNDAgTDIwIDIwIE0yMCAyMCBMNDAgMCBNMCAyMCBMMjAgMCBNMjAgNDAgTDQwIDIwIiBzdHJva2U9IiNlNWU3ZWIiIHN0cm9rZS13aWR0aD0iMSIgZmlsbD0ibm9uZSIvPjwvc3ZnPg==\')] overflow-hidden opacity-50\"></div>\n        </div>\n\n        {/* 2. Lektion */}\n         <div className=\"grid grid-cols-[80px_repeat(5,1fr)] border-b border-outline-variant group hover:bg-surface-container/30 transition-colors\">\n          <div className=\"p-3 text-center border-r border-outline-variant border-dashed flex flex-col justify-center bg-surface-container-low/50\">\n             <span className=\"font-label-md font-bold text-on-surface\">2</span>\n            <span className=\"text-label-sm 