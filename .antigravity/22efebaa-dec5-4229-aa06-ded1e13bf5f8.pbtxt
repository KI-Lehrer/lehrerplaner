    replacement_chunks {
      replacement_content: "import React from \'react\';\n\nexport default function Aufgaben() {\n  return (\n    <div className=\"p-6 md:p-margin-desktop max-w-[1440px] mx-auto w-full\">\n      <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-4 mb-lg\">\n        <h2 className=\"font-headline-lg text-headline-lg font-semibold text-primary\">Aufgaben</h2>\n        <div className=\"flex flex-wrap gap-2\">\n          <button className=\"px-5 py-2 rounded-full bg-primary text-on-primary font-label-md hover:bg-primary/90 transition-colors\">Alle Aufgaben</button>\n          <button className=\"px-5 py-2 rounded-full border border-outline-variant text-on-surface-variant hover:bg-surface-container-low transition-colors font-label-md\">Dringend</button>\n          <button className=\"px-5 py-2 rounded-full border border-outline-variant text-on-surface-variant hover:bg-surface-container-low transition-colors font-label-md\">Diese Woche</button>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter overflow-x-auto pb-8\">\n        \n        {/* Kolumne: Korrekturen */}\n        <div className=\"flex flex-col gap-4 min-h-[500px]\">\n          <div className=\"flex items-center justify-between px-2 mb-2\">\n            <div className=\"flex items-center gap-3\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-error\"></span>\n              <h3 className=\"font-title-md text-title-md\">Korrekturen</h3>\n              <span className=\"text-label-sm px-2 py-0.5 rounded-full bg-surface-container-high\">3</span>\n            </div>\n            <button className=\"text-on-surface-variant hover:bg-surface-container-high p-1 rounded-full transition-colors\">\n              <span className=\"material-symbols-outlined\">more_vert</span>\n            </button>\n          </div>\n          \n          <div className=\"space-y-4\">\n            <div className=\"bg-surface-container-lowest border border-outline-variant p-4 rounded-xl hover:shadow-md transition-all cursor-grab active:cursor-grabbing sheet-shadow\">\n              <div className=\"flex items-start justify-between mb-3\">\n                <span className=\"bg-error/10 text-error text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded\">Prio 1</span>\n                <span className=\"text-label-sm text-on-surface-variant italic\">Heute</span>\n              </div>\n              <p className=\"font-title-md font-semibold text-on-surface mb-2\">Mathetest Klasse 9b korrigieren</p>\n              <p className=\"text-label-sm text-on-surface-variant line-clamp-2 mb-4 leading-relaxed\">28 Arbeiten, Schwerpunkt: Lineare Gleichungssysteme.</p>\n              <div className=\"flex items-center justify-between pt-2\">\n                <div className=\"w-7 h-7 rounded-full bg-secondary-container flex items-center justify-center text-[10px] font-bold text-on-secondary-container border border-surface-container-lowest\">9B</div>\n                <div className=\"flex items-center gap-1.5 text-on-surface-variant pt-1\">\n                  <span className=\"material-symbols-outlined text-[18px]\">attachment</span>\n                  <span className=\"text-label-sm font-semibold\">2</span>\n                </div>\n              </div>\n            </div>\n\n            <div className=\"bg-surface-container-lowest border border-outline-variant p-4 rounded-xl hover:shadow-md transition-all cursor-grab active:cursor-grabbing sheet-shadow\">\n              <div className=\"flex items-start justify-between mb-3\">\n                <span className=\"bg-primary/10 text-primary text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded\">Prio 2</span>\n                <span className=\"text-label-sm text-on-surface-variant\">Fr, 14:00</span>\n              </div>\n              <p className=\"font-title-md font-semibold text-on-surface mb-1\">Diktat Kl. 5a</p>\n              <div className=\"w-full bg-surface-container-low h-1.5 rounded-full mt-4 overflow-hidden\">\n                <div className=\"bg-secondary h-full\" style={{ width: \'45%\' }}></div>\n              </div>\n              <div className=\"flex justify-between items-center mt-3\">\n                <span className=\"text-[10px] text-on-surface-variant font-semibold\">45% fertig</span>\n                <span className=\"material-symbols-outlined text-secondary text-[18px]\">check_circle</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Kolumne: Vorbereitung */}\n        <div className=\"flex flex-col gap-4 min-h-[500px]\">\n          <div className=\"flex items-center justify-between px-2 mb-2\">\n            <div className=\"flex items-center gap-3\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-primary\"></span>\n              <h3 className=\"font-title-md text-title-md\">Vorbereitung</h3>\n              <span className=\"text-label-sm px-2 py-0.5 rounded-full bg-surface-container-high\">2</span>\n            </div>\n          </div>\n          \n          <div className=\"space-y-4\">\n            <div className=\"bg-surface-container-lowest border border-outline-variant p-4 rounded-xl hover:shadow-md transition-all cursor-grab active:cursor-grabbing sheet-shadow\">\n              <div className=\"flex items-start justify-between mb-3\">\n                <span className=\"bg-tertiary-container/20 text-tertiary text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded\">Bio</span>\n                <span className=\"text-label-sm text-on-surface-variant\">Mo, 08:00</span>\n              </div>\n              <p className=\"font-title-md font-semibold text-on-surface mb-2\">Stationenlernen Zellbiologie</p>\n              <p className=\"text-label-sm text-on-surface-variant mb-4 leading-relaxed\">Materialien laminieren und QR-Codes drucken.</p>\n              <div className=\"flex items-center gap-2 pt-1 border-t border-outline-variant/30\">\n                <span className=\"material-symbols-outlined text-[18px] text-on-surface-variant mt-2\">link</span>\n                <span className=\"text-label-sm text-primary underline mt-2 cursor-pointer\">Planung_Zelle_V3.pdf</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Kolumne: Elternarbeit */}\n        <div className=\"flex flex-col gap-4 min-h-[500px]\">\n          <div className=\"flex items-center justify-between px-2 mb-2\">\n            <div className=\"flex items-center gap-3\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-secondary\"></span>\n              <h3 className=\"font-title-md text-title-md\">Elternarbeit</h3>\n              <span className=\"text-label-sm px-2 py-0.5 rounded-full bg-surface-container-high\">1</span>\n            </div>\n          </div>\n          \n          <div className=\"space-y-4\">\n            <div className=\"bg-surface-container-lowest border border-outline-variant p-4 rounded-xl hover:shadow-md transition-all cursor-grab active:cursor-grabbing sheet-shadow relative overflow-hidden\">\n              <div className=\"absolute top-0 left-0 w-1 h-full bg-error\"></div>\n              <div className=\"flex items-start justify-between mb-3 pl-2\">\n                <span className=\"bg-outline/10 text-on-surface-variant text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded\">Anruf</span>\n                <span className=\"text-label-sm text-error font-semibold\">\303\234berf\303\244llig</span>\n              </div>\n              <p className=\"font-title-md font-semibold text-on-surface mb-2 pl-2\">R\303\274ckmeldung Fam. M\303\274ller</p>\n              <p className=\"text-label-sm text-on-surface-variant mb-5 leading-relaxed pl-2\">Wegen Klassenfahrt-Anmeldung und Allergien.</p>\n              <div className=\"pl-2\">\n                <button className=\"w-full bg-surface-container py-2.5 rounded-lg text-label-md text-on-surface-variant hover:bg-surface-container-high transition-colors flex items-center justify-center gap-2 font-semibold\">\n                  <span className=\"material-symbols-outlined text-[18px]\">call</span>\n                  Jetzt anrufen\n                </button>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        {/* Kolumne: Verwaltung */}\n        <div className=\"flex flex-col gap-4 min-h-[500px]\">\n          <div className=\"flex items-center justify-between px-2 mb-2\">\n            <div className=\"flex items-center gap-3\">\n              <span className=\"w-2.5 h-2.5 rounded-full bg-outline\"></span>\n              <h3 className=\"font-title-md text-title-md text-on-surface-variant\">Verwaltung</h3>\n              <span className=\"text-label-sm px-2 py-0.5 rounded-full bg-surface-container-high text-on-surface-variant\">0</span>\n            </div>\n          </div>\n          \n          <div className=\"flex flex-col items-center justify-center py-xl border-2 border-dashed border-outline-variant rounded-2xl opacity-50 bg-surface/50 h-[300px]\">\n            <span className=\"material-symbols-outlined text-4xl mb-3 text-outline\">inventory_2</span>\n            <p className=\"text-label-sm text-outline font-semibold\">Keine offenen Aufgaben</p>\n          </div>\n        </div>\n        \n      </div>\n    </div>\n  );\n}"
    }
